BOT_TOKEN=your_telegram_bot_token_here
# Docker Compose default — change to http://localhost:11434 for local dev without Docker
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3.5
OLLAMA_CHAT_MODEL=phi3.5  # model used for general chat (can differ from the classifier model)
# Optional: comma-separated Telegram user IDs to whitelist. Leave empty to allow anyone.
ALLOWED_USER_IDS=
# Webhook mode (set USE_WEBHOOK=true for cloud deployments; leave false for local/Unraid polling)
USE_WEBHOOK=false
WEBHOOK_URL=
# Optional but recommended in webhook mode: a secret string shared with Telegram.
# Set it here and pass the same value as secret_token when calling setWebhook (or via the
# Telegram BotFather). The bot will reject any /telegram POST that doesn't include a matching
# X-Telegram-Bot-Api-Secret-Token header, preventing spoofed update injection.
WEBHOOK_SECRET=
PORT=8080
