BOT_TOKEN=your_telegram_bot_token_here
# Docker Compose default — change to http://localhost:11434 for local dev without Docker
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3.5
OLLAMA_CHAT_MODEL=phi3.5  # model used for general chat (can differ from the classifier model)
# Optional: comma-separated Telegram user IDs to whitelist. Leave empty to allow anyone.
ALLOWED_USER_IDS=
# Webhook mode (set USE_WEBHOOK=true for cloud deployments; leave false for local/Unraid polling)
USE_WEBHOOK=false
# Public HTTPS base URL only — no trailing slash, no path. The bot appends /telegram itself.
# Example: https://bot.example.com
WEBHOOK_URL=
# Optional but recommended in webhook mode: a secret string shared with Telegram.
# When set, the bot passes it to setWebhook automatically AND rejects any incoming
# /telegram POST whose X-Telegram-Bot-Api-Secret-Token header doesn't match — preventing
# spoofed update injection. No manual BotFather step required.
WEBHOOK_SECRET=
PORT=8080
